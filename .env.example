# ── MinIO / S3 credentials ─────────────────────────────────────────────────────
# REQUIRED in production — change both values before deploying.
# These are used by the minio service AND forwarded to the API server/workers
# via S3__ACCESS_KEY_ID / S3__SECRET_ACCESS_KEY.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── API authentication ──────────────────────────────────────────────────────────
# Set one of the two options below to protect the transcription endpoints.
# Single key:
# API_KEY=your-secret-key
# JSON file mapping key → client name (see dependencies.py for format):
# API_KEYS_FILE=/run/secrets/api_keys.json

# ── Hugging Face token ──────────────────────────────────────────────────────────
# Required for gated models (e.g. pyannote diarization).
# HF_TOKEN=hf_...

# ── Whisper model ───────────────────────────────────────────────────────────────
# WHISPER__MODEL=large-v3
# WHISPER__COMPUTE_TYPE=float16      # int8 | float16 | bfloat16 | float32
# WHISPER__INFERENCE_DEVICE=cuda     # cpu | cuda | auto
# WHISPER__BATCH_SIZE=12
# WHISPER__CHUNK_SIZE=30

# ── Concurrency / performance ───────────────────────────────────────────────────
# MAX_CONCURRENT_TRANSCRIPTIONS=1   # GPU slots; 1 is safe for a single GPU
# IO_EXECUTOR_WORKERS=4

# ── Kafka (distributed mode only) ──────────────────────────────────────────────
# KAFKA__BOOTSTRAP_SERVERS=kafka:9092
# KAFKA__REQUEST_TOPIC=transcription-requests
# KAFKA__REPLY_TOPIC=transcription-replies
# KAFKA__REPLY_TIMEOUT_SECONDS=300
# KAFKA__MAX_PENDING_JOBS=0         # 0 = unlimited

# ── S3 / MinIO (distributed mode only) ─────────────────────────────────────────
# S3__ENDPOINT_URL=http://minio:9000
# S3__BUCKET=whisperx-audio
# S3__REGION=us-east-1
# S3__OBJECT_EXPIRY_DAYS=1          # Days before uploaded audio is auto-deleted

# ── Logging ─────────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ── CORS ────────────────────────────────────────────────────────────────────────
# ALLOW_ORIGINS=["https://your-frontend.example.com"]
